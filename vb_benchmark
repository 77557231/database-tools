[CPU Test]
  Enabled: ${CPU_ENABLED:-true}
  Threads: $(if [ "${CPU_THREADS:-0}" = "0" ]; then echo "auto ($cpu_cores)"; else echo "${CPU_THREADS}"; fi)
  Duration: ${unified_duration}s
  Max Prime: ${CPU_MAX_PRIME:-20000}

[Memory Test]
  Enabled: ${MEMORY_ENABLED:-true}
  Block Size: ${MEMORY_BLOCK_SIZE:-8K}
  Total Size: ${MEMORY_TOTAL_SIZE:-20G}
  Operation: ${MEMORY_OPER:-read}
  Duration: ${unified_duration}s

[IO Test]
  Enabled: ${IO_ENABLED:-true}
  Tool: ${IO_TOOL:-sysbench}
  File Size: ${IO_TOTAL_SIZE:-100M}
  Test Mode: ${IO_TEST_MODE:-rndrw}
  Duration: $(if [ "${IO_TOOL:-sysbench}" = "fio" ]; then echo "${FIO_DURATION:-$unified_duration}s"; else echo "${unified_duration}s"; fi)

[Network Test]
  Enabled: ${NETWORK_ENABLED:-true}
  Tool: ${NETWORK_TOOL:-iperf3}
  Server: ${NETWORK_SERVER_IP:-auto}
  Port: ${NETWORK_PORT:-25201}
  Duration: ${unified_duration}s
  Parallel: ${NETWORK_PARALLEL:-1}

[Threads Test]
  Enabled: ${THREADS_ENABLED:-true}
  Threads: ${THREADS_NUM:-100}
  Duration: ${unified_duration}s
  Yields: ${THREADS_YIELDS:-100}
  Locks: ${THREADS_LOCKS:-4}

[Mutex Test]
  Enabled: ${MUTEX_ENABLED:-true}
  Threads: $(if [ "${MUTEX_THREADS:-0}" = "0" ]; then echo "auto ($cpu_cores)"; else echo "${MUTEX_THREADS}"; fi)
  Duration: ${unified_duration}s
  Mutex Num: ${MUTEX_NUM:-1024}

[pgbench Test]
  Enabled: ${PGBENCH_ENABLED:-false}
  Database: ${PGBENCH_DB:-pgbench_db}
  Duration: ${PGBENCH_DURATION:-300}s
  Threads: $(if [ "${PGBENCH_THREADS:-0}" = "0" ]; then echo "auto ($cpu_cores)"; else echo "${PGBENCH_THREADS}"; fi)

================================================================================
                           Test Results Summary
================================================================================

[CPU Test]
EOF

    # Parse CPU results from combined file
    if [ -f "$combined_file" ]; then
        local cpu_events=$(grep -A1 "CPU speed:" "$combined_file" 2>/dev/null | grep "events per second" | awk '{print $NF}')
        local cpu_avg_lat=$(grep -A30 "CPU TEST RESULTS" "$combined_file" 2>/dev/null | grep -A5 "Latency (ms):" | grep "avg:" | awk '{print $NF}')
        local cpu_p95_lat=$(grep -A30 "CPU TEST RESULTS" "$combined_file" 2>/dev/null | grep "95th percentile" | awk '{print $NF}')
        local cpu_p99_lat=$(grep -A30 "CPU TEST RESULTS" "$combined_file" 2>/dev/null | grep "99th percentile" | awk '{print $NF}')
        local cpu_threads_fairness_events=$(grep -A50 "CPU TEST RESULTS" "$combined_file" 2>/dev/null | grep "Threads fairness:" -A2 | grep "events" | head -1)
        local cpu_threads_fairness_time=$(grep -A50 "CPU TEST RESULTS" "$combined_file" 2>/dev/null | grep "Threads fairness:" -A2 | grep "execution time" | head -1)

        if [ -n "$cpu_events" ]; then
            cat >> "$report_file" << EOF
  CPU speed:
    events per second: ${cpu_events}
  Avg Latency:   ${cpu_avg_lat:-0} ms
  P95 Latency:   ${cpu_p95_lat:-0} ms
EOF
            if [ -n "$cpu_p99_lat" ] && [ "$cpu_p99_lat" != "0" ]; then
                echo "  P99 Latency:   ${cpu_p99_lat} ms" >> "$report_file"
            fi
            if [ -n "$cpu_threads_fairness_events" ] || [ -n "$cpu_threads_fairness_time" ]; then
                echo "  Threads fairness:" >> "$report_file"
                if [ -n "$cpu_threads_fairness_events" ]; then
                    echo "    ${cpu_threads_fairness_events}" >> "$report_file"
                fi
                if [ -n "$cpu_threads_fairness_time" ]; then
                    echo "    ${cpu_threads_fairness_time}" >> "$report_file"
                fi
            fi
        else
            echo "  Test not executed" >> "$report_file"
        fi
    fi

    cat >> "$report_file" << EOF

[Memory Test]
EOF

    if [ -f "$combined_file" ]; then
        # Extract total operations and per second from the output
        local mem_total_ops_line=$(grep "Total operations:" "$combined_file" 2>/dev/null)
        local mem_total_ops=$(echo "$mem_total_ops_line" | awk '{print $3}')
        local mem_ops_sec=$(echo "$mem_total_ops_line" | awk -F'[()]' '{print $2}' | awk '{print $1}')
        local mem_transferred=$(grep "MiB transferred" "$combined_file" 2>/dev/null | awk '{print $1}')
        local mem_mib_sec=$(grep "MiB transferred" "$combined_file" 2>/dev/null | awk -F'[()]' '{print $2}' | awk '{print $1}')
        local mem_avg_lat=$(grep -A30 "MEMORY TEST RESULTS" "$combined_file" 2>/dev/null | grep -A5 "Latency (ms):" | grep "avg:" | awk '{print $NF}')
        local mem_p95_lat=$(grep -A30 "MEMORY TEST RESULTS" "$combined_file" 2>/dev/null | grep "95th percentile" | awk '{print $NF}')

        if [ -n "$mem_total_ops" ]; then
            cat >> "$report_file" << EOF
  Total operations: ${mem_total_ops} (${mem_ops_sec} per second)
  Transferred:      ${mem_transferred} MiB (${mem_mib_sec} MiB/sec)
  Avg Latency:      ${mem_avg_lat:-0} ms
  P95 Latency:      ${mem_p95_lat:-0} ms
EOF
        else
            echo "  Test not executed" >> "$report_file"
        fi
    fi

    cat >> "$report_file" << EOF

[IO Test]
EOF

    if [ -f "$combined_file" ]; then
        local io_read_iops=$(grep "reads/s:" "$combined_file" 2>/dev/null | awk '{print $NF}')
        local io_write_iops=$(grep "writes/s:" "$combined_file" 2>/dev/null | awk '{print $NF}')
        local io_read_bw=$(grep "read, MiB/s:" "$combined_file" 2>/dev/null | awk '{print $NF}')
        local io_write_bw=$(grep "written, MiB/s:" "$combined_file" 2>/dev/null | awk '{print $NF}')
        local io_avg_lat=$(grep "avg:" "$combined_file" 2>/dev/null | tail -1 | awk '{print $NF}' | tr -d ',')

        if [ -n "$io_read_iops" ]; then
            local io_total_iops=$(awk "BEGIN {printf \"%.2f\", $io_read_iops + $io_write_iops}")
            local io_total_bw=$(awk "BEGIN {printf \"%.2f\", $io_read_bw + $io_write_bw}")

            cat >> "$report_file" << EOF
  Read IOPS:        ${io_read_iops}
  Write IOPS:       ${io_write_iops}
  Total IOPS:       ${io_total_iops}
  Read BW:          ${io_read_bw} MB/s
  Write BW:         ${io_write_bw} MB/s
  Total BW:         ${io_total_bw} MB/s
  Avg Latency:      ${io_avg_lat:-0} ms
EOF
        else
            echo "  Test not executed" >> "$report_file"
        fi
    fi

    cat >> "$report_file" << EOF

[Threads Test]
EOF

    if [ -f "$combined_file" ]; then
        local threads_events=$(grep -A30 "THREADS TEST RESULTS" "$combined_file" 2>/dev/null | grep "total number of events:" | awk '{print $NF}')
        local threads_time=$(grep -A30 "THREADS TEST RESULTS" "$combined_file" 2>/dev/null | grep "total time:" | awk '{print $NF}' | tr -d 's')
        local threads_avg_lat=$(grep -A30 "THREADS TEST RESULTS" "$combined_file" 2>/dev/null | grep -A5 "Latency (ms):" | grep "avg:" | awk '{print $NF}')
        local threads_p95_lat=$(grep -A30 "THREADS TEST RESULTS" "$combined_file" 2>/dev/null | grep "95th percentile" | awk '{print $NF}')

        if [ -n "$threads_events" ]; then
            local threads_eps=$(awk "BEGIN {printf \"%.2f\", $threads_events / ${threads_time:-1}}")

            cat >> "$report_file" << EOF
  Events/sec:     ${threads_eps}
  Avg Latency:    ${threads_avg_lat:-0} ms
  P95 Latency:    ${threads_p95_lat:-0} ms
EOF
        else
            echo "  Test not executed" >> "$report_file"
        fi
    fi

    cat >> "$report_file" << EOF

[Mutex Test]
EOF

    if [ -f "$combined_file" ]; then
        local mutex_events=$(grep -A30 "MUTEX TEST RESULTS" "$combined_file" 2>/dev/null | grep "total number of events:" | awk '{print $NF}')
        local mutex_time=$(grep -A30 "MUTEX TEST RESULTS" "$combined_file" 2>/dev/null | grep "total time:" | awk '{print $NF}' | tr -d 's')
        local mutex_avg_lat=$(grep -A30 "MUTEX TEST RESULTS" "$combined_file" 2>/dev/null | grep -A5 "Latency (ms):" | grep "avg:" | awk '{print $NF}')
        local mutex_p95_lat=$(grep -A30 "MUTEX TEST RESULTS" "$combined_file" 2>/dev/null | grep "95th percentile" | awk '{print $NF}')

        if [ -n "$mutex_events" ]; then
            local mutex_tps=$(awk "BEGIN {printf \"%.2f\", $mutex_events / ${mutex_time:-1}}")

            cat >> "$report_file" << EOF
  Transactions:   ${mutex_events}
  TPS:            ${mutex_tps}
  Avg Latency:    ${mutex_avg_lat:-0} ms
  P95 Latency:    ${mutex_p95_lat:-0} ms
EOF
        else
            echo "  Test not executed" >> "$report_file"
        fi
    fi

    cat >> "$report_file" << EOF

[Network Test]
EOF

    if [ -f "$combined_file" ]; then
        # Check if network test results exist
        if grep -q "NETWORK TEST RESULTS" "$combined_file" 2>/dev/null; then
            # Extract all network test results for each client
            local found_results=false

            # Get the output directory from the combined file path
            local output_dir=$(dirname "$combined_file")

            # Get all network test scenarios
            local scenario_count=$(grep -c "NETWORK TEST RESULTS" "$combined_file")

            # Process each scenario
            local i=1
            while [ $i -le $scenario_count ]; do
                # Find the corresponding JSON file
                local json_file="$output_dir/network_scenario_${i}.json"
                local net_bw="0"
                local client_ip="N/A"

                if [ -f "$json_file" ]; then
                    # Check if jq is installed
                    if command -v jq &> /dev/null; then
                        # Extract bandwidth from JSON file
                        local bandwidth_bps=$(jq -r '.end.sum_received.bits_per_second // 0' "$json_file" 2>/dev/null)
                        # Convert bps to MB/s: 1 MB/s = 8,000,000 bps
                        net_bw=$(awk "BEGIN {printf \"%.2f\", $bandwidth_bps / 8000000}" 2>/dev/null || echo "0")
                        
                        # Extract client IP from the JSON file
                        client_ip=$(jq -r '.start.client.host // "N/A"' "$json_file" 2>/dev/null)
                        if [ -z "$client_ip" ] || [ "$client_ip" = "null" ] || [ "$client_ip" = "N/A" ]; then
                            # Fallback: get client IP from the file name or use a generic name
                            local scenario_idx=$(echo "$json_file" | grep -oP 'network_scenario_\K[0-9]+' | head -1)
                            client_ip="Client $scenario_idx"
                        fi
                    fi
                fi
                
                # Display the result for this client
                echo "  $client_ip: ${net_bw} MB/s"
                # Write to report file
                echo "  $client_ip: ${net_bw} MB/s" >> "$report_file"
                found_results=true
                
                i=$((i + 1))
            done
            
            if [ "$found_results" = false ]; then
                echo "  Test not executed or no results found"
            fi
        else
            echo "  Test not executed"
        fi
    fi
    
    # Add pgbench results if available
    cat >> "$report_file" << EOF

[pgbench Test]
EOF
    
    if [ -f "$combined_file" ]; then
        if grep -q "PGBENCH TEST RESULTS" "$combined_file" 2>/dev/null; then
            local pgbench_results=$(grep -A20 "PGBENCH TEST RESULTS" "$combined_file" 2>/dev/null)
            if [ -n "$pgbench_results" ]; then
                echo "$pgbench_results" >> "$report_file"
            else
                echo "  Test not executed"
            fi
        else
            echo "  Test not executed"
        fi
    else
        echo "  Test not executed"
    fi
    
    # Finalize report
    cat >> "$report_file" << EOF

================================================================================
                                End of Report
================================================================================
EOF
    

}

# Main function
main() {
    # Parse command line arguments
    parse_args "$@"
    
    # Set timestamp
    TIMESTAMP=$(date '+%Y%m%d_%H%M%S')
    
    # Create output directory
    mkdir -p "$OUTPUT_DIR"
    
    # Load configuration file
    if [ -n "$CONFIG_FILE" ]; then
        load_config "parameter" "$CONFIG_FILE"
    else
        # Default to parameter.conf
        local default_config="${SCRIPT_DIR}/parameter.conf"
        if [ -f "$default_config" ]; then
            load_config "parameter" "$default_config"
        else
            # Try to find in config directory
            local config_dir_config="${SCRIPT_DIR}/config/parameter.conf"
            if [ -f "$config_dir_config" ]; then
                load_config "parameter" "$config_dir_config"
            else
                echo "错误：找不到配置文件 parameter.conf"
                echo "请确保配置文件存在于以下位置之一："
                echo "  - ${SCRIPT_DIR}/parameter.conf"
                echo "  - ${SCRIPT_DIR}/config/parameter.conf"
                exit 1
            fi
        fi
    fi
    
    # Process command line arguments again to ensure they override config file values
    parse_args "$@"
    
    # Process server list (supports file or direct IP list)
    local target_servers=()
    local local_ip=$(get_machine_ip)
    local include_local=false
    if [ -n "$SERVERS_FILE" ]; then
        if [ -f "$SERVERS_FILE" ]; then
            # Read server IP list from file
            local servers=()
            mapfile -t servers < "$SERVERS_FILE"
            
            # Process each IP, remove whitespace and newlines
            local filtered_servers=()
            for ip in "${servers[@]}"; do
                ip=$(echo "$ip" | tr -d '\r' | xargs)
                if [ -n "$ip" ]; then
                    filtered_servers+=("$ip")
                    if [ "$ip" = "$local_ip" ]; then
                        include_local=true
                    fi
                fi
            done
            target_servers=(${filtered_servers[@]})
        else
            # Process SERVERS_FILE directly as IP list
            local ip_list=($SERVERS_FILE)
            local filtered_ips=()
            for ip in "${ip_list[@]}"; do
                ip=$(echo "$ip" | xargs)
                if [ -n "$ip" ]; then
                    filtered_ips+=("$ip")
                    if [ "$ip" = "$local_ip" ]; then
                        include_local=true
                    fi
                fi
            done
            target_servers=(${filtered_ips[@]})
        fi
        
        if [ ${#target_servers[@]} -gt 0 ]; then
            # Local machine as iPerf3 server
            local server_ip=$(get_machine_ip)
            # All IPs as clients
            local client_ips=""
            for ip in "${target_servers[@]}"; do
                client_ips+="$ip "
            done
            client_ips=$(echo "$client_ips" | xargs)
            
            echo "从服务器列表加载配置："
            echo "  服务器IP: $server_ip (本机)"
            echo "  客户端IP: $client_ips"
            echo "  本机作为iPerf3服务器"
            
            # Set network test parameters
            export NETWORK_SERVER_IP="$server_ip"
            export NETWORK_CLIENT_IP="$client_ips"
        fi
    fi
    
    # Update OUTPUT_DIR environment variable
    export OUTPUT_DIR
    
    # Install and distribute sysbench if -i option is specified
    if [ "${SYSBENCH_INSTALL:-false}" = "true" ]; then
        install_and_distribute_sysbench
        echo ""
        echo "=== Sysbench installation completed successfully! ==="
        exit 0
    fi
    
    # Run checks
    check_all
    
    # Run tests
    if [ ${#target_servers[@]} -gt 0 ]; then
        # Execute tests for each target server
        local server_idx=0
        for target_ip in "${target_servers[@]}"; do
            server_idx=$((server_idx + 1))
            echo ""
            echo "================================================================================"
            echo "Testing server $server_idx/$(( ${#target_servers[@]} )): $target_ip"
            echo "================================================================================"
            
            # Only execute tests if target IP is local machine or include_local is true
            if [ "$target_ip" = "$local_ip" ] || [ "$include_local" = "true" ]; then
                # Here you can add remote test execution logic
                # For example: Execute tests on remote servers via SSH
                # Currently executing locally, can be extended to remote execution later
                
                if [ "$CPU_ENABLED" != "false" ]; then
                    run_cpu_test
                fi
                
                if [ "$MEMORY_ENABLED" != "false" ]; then
                    run_memory_test
                fi
                
                if [ "$IO_ENABLED" != "false" ]; then
                    run_io_test
                fi
                
                if [ "$THREADS_ENABLED" != "false" ]; then
                    run_threads_test
                fi
                
                if [ "$MUTEX_ENABLED" != "false" ]; then
                    run_mutex_test
                fi
                
                if [ "$PGBENCH_ENABLED" = "true" ]; then
                    run_pgbench_test
                fi
            else
                echo "  Skipping local tests: local machine not in server list"
            fi
        done
        
        # Execute network test
        if [ "$NETWORK_ENABLED" != "false" ]; then
            run_network_test
        fi
    else
        # Single machine test mode
        if [ "$CPU_ENABLED" != "false" ]; then
            run_cpu_test
        fi
        
        if [ "$MEMORY_ENABLED" != "false" ]; then
            run_memory_test
        fi
        
        if [ "$IO_ENABLED" != "false" ]; then
            run_io_test
        fi
        
        if [ "$NETWORK_ENABLED" != "false" ]; then
            run_network_test
        fi
        
        if [ "$THREADS_ENABLED" != "false" ]; then
            run_threads_test
        fi
        
        if [ "$MUTEX_ENABLED" != "false" ]; then
            run_mutex_test
        fi
        
        if [ "$PGBENCH_ENABLED" = "true" ]; then
            run_pgbench_test
        fi
    fi
    
    # Generate report
    generate_report
    
    echo ""
    echo "=== Benchmark completed successfully! ==="
    echo "Report: $OUTPUT_DIR/report_benchmark_${TIMESTAMP}.txt"
    echo "Detailed results: $OUTPUT_DIR/data_${TIMESTAMP}_all_results.txt"
}

# Install and distribute sysbench to target servers
install_and_distribute_sysbench() {
    local local_ip=$(get_machine_ip)
    local sysbench_dir="$HOME/sysbench"
    local need_compile=false
    
    echo "=== Sysbench Installation and Distribution ==="
    
    # Check if local machine is in server list and needs compilation
    if [ ${#target_servers[@]} -gt 0 ]; then
        # Multi-server mode: check if local machine is in server list
        local is_local_in_list=false
        for ip in "${target_servers[@]}"; do
            if [ "$ip" = "$local_ip" ]; then
                is_local_in_list=true
                break
            fi
        done
        
        # If local machine is in list and no sysbench directory, need to compile
        if [ "$is_local_in_list" = "true" ] && [ ! -d "$sysbench_dir" ]; then
            need_compile=true
        fi
        
        # Compile sysbench if needed
        if [ "$need_compile" = "true" ]; then
            echo "[Step 1/3] Installing dependencies and compiling sysbench on local machine..."
            echo "  Local IP: $local_ip"
            echo "  Sysbench directory: $sysbench_dir"
            
            # Check if dependencies are already installed
            echo "  Checking build dependencies..."
            if ! command -v gcc &> /dev/null || ! command -v make &> /dev/null || ! command -v automake &> /dev/null; then
                echo "  Installing build dependencies..."
                run_command "sudo yum install -y automake autoconf libtool gcc gcc-c++ make" "/dev/null"
            else
                echo "  Build dependencies already installed, skipping"
            fi
            
            # Compile sysbench
            echo "  Compiling sysbench..."
            run_command "tar -zxf tools/sysbench-1.0.20.tar.gz && cd sysbench-1.0.20 && ./autogen.sh && ./configure --without-mysql --prefix=\$HOME/sysbench && make && make install" "/dev/null"
            
            # Configure environment
            echo "  Configuring environment variables..."
            run_command "echo 'export PATH=\$PATH:\$HOME/sysbench/bin' >> ~/.bashrc && source ~/.bashrc" "/dev/null"
            
            # Cleanup source directory
            run_command "rm -rf sysbench-1.0.20" "/dev/null"
            
            # Verify installation
            if [ -d "$sysbench_dir" ]; then
                echo "  ✓ sysbench compiled and installed successfully"
            else
                echo "  ✗ sysbench compilation failed"
                return 1
            fi
        else
            if [ -d "$sysbench_dir" ]; then
                echo "[Step 1/3] sysbench directory exists on local machine, skipping compilation"
                echo "  Local IP: $local_ip"
                echo "  Sysbench directory: $sysbench_dir"
            else
                echo "[Step 1/3] Skipping compilation: local machine not in server list"
            fi
        fi
        
        # Distribute sysbench to other servers if it exists
        if [ -d "$sysbench_dir" ]; then
            echo "[Step 2/3] Distributing sysbench to target servers..."
            echo "  Server list: ${target_servers[*]}"
            
            # Create tar package
            local tar_file="$HOME/sysbench.tar.gz"
            echo "  Creating tar package: $tar_file"
            run_command "tar -czf $tar_file -C $HOME sysbench" "/dev/null"
            
            # SCP to each server except local machine
            for ip in "${target_servers[@]}"; do
                if [ "$ip" != "$local_ip" ]; then
                    echo "  Distributing to $ip..."
                    run_command "scp -q $tar_file $ip:$HOME/" "/dev/null"
                    run_command "ssh -q $ip 'tar -xzf \$HOME/sysbench.tar.gz -C \$HOME && rm -f \$HOME/sysbench.tar.gz && echo '\''export PATH=\$PATH:\$HOME/sysbench/bin'\'' >> ~/.bashrc && source ~/.bashrc && sysbench --version'" "/dev/null"
                    echo "  ✓ Successfully distributed to $ip"
                fi
            done
            
            # Cleanup tar file
            run_command "rm -f $tar_file" "/dev/null"
            
            echo "  ✓ sysbench distributed to all target servers"
        fi
        
        echo "[Step 3/3] Installation and distribution completed"
    else
        # Single machine mode
        if [ ! -d "$sysbench_dir" ]; then
            echo "[Step 1/3] Installing dependencies and compiling sysbench..."
            echo "  Sysbench directory: $sysbench_dir"
            
            # Check if dependencies are already installed
            echo "  Checking build dependencies..."
            if ! command -v gcc &> /dev/null || ! command -v make &> /dev/null || ! command -v automake &> /dev/null; then
                echo "  Installing build dependencies..."
                run_command "sudo yum install -y automake autoconf libtool gcc gcc-c++ make" "/dev/null"
            else
                echo "  Build dependencies already installed, skipping"
            fi
            
            # Compile sysbench
            echo "  Compiling sysbench..."
            run_command "tar -zxf tools/sysbench-1.0.20.tar.gz && cd sysbench-1.0.20 && ./autogen.sh && ./configure --without-mysql --prefix=\$HOME/sysbench && make && make install" "/dev/null"
            
            # Configure environment
            echo "  Configuring environment variables..."
            run_command "echo 'export PATH=\$PATH:\$HOME/sysbench/bin' >> ~/.bashrc && source ~/.bashrc" "/dev/null"
            
            # Cleanup source directory
            run_command "rm -rf sysbench-1.0.20" "/dev/null"
            
            # Verify installation
            if [ -d "$sysbench_dir" ]; then
                echo "  ✓ sysbench compiled and installed successfully"
            else
                echo "  ✗ sysbench compilation failed"
                return 1
            fi
        else
            echo "  ✓ sysbench directory already exists: $sysbench_dir"
        fi
    fi
}

# 执行主函数
main "$@"