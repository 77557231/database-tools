# Export immediately for library functions
export OUTPUT_DIR

# Parse command line arguments
parse_args() {
    local OPTIND=1
    local remaining_args=()
    
    # First pass: extract options and their arguments
    while [ $OPTIND -le $# ]; do
        case "${!OPTIND}" in
            --)
                # End of options
                local OPTIND=$((OPTIND + 1))
                break
                ;;
            --*)
                # Long options
                local opt="${!OPTIND}"
                local opt_name="${opt:2}"
                case "$opt_name" in
                    help)
                        show_help
                        exit 0
                        ;;
                    dry-run)
                        DRY_RUN=true
                        ;;
                    *)
                        echo "Unknown option: $opt"
                        show_help
                        exit 1
                        ;;
                esac
                local OPTIND=$((OPTIND + 1))
                ;;
            -[codhi])
                # Single letter options (no argument)
                local opt_char="${!OPTIND:1:1}"
                case "$opt_char" in
                    d)
                        DRY_RUN=true
                        ;;
                    h)
                        show_help
                        exit 0
                        ;;
                    i)
                        SYSBENCH_INSTALL=true
                        ;;
                esac
                local OPTIND=$((OPTIND + 1))
                ;;
            -[cof])
                # Options that require an argument
                local opt_char="${!OPTIND:1:1}"
                local OPTIND=$((OPTIND + 1))
                local opt_arg="${!OPTIND}"
                case "$opt_char" in
                    c)
                        CONFIG_FILE="$opt_arg"
                        ;;
                    o)
                        OUTPUT_DIR="$opt_arg"
                        ;;
                    f)
                        SERVERS_FILE="$opt_arg"
                        ;;
                esac
                local OPTIND=$((OPTIND + 1))
                ;;
            -[^-]*)
                # Unknown option starting with single dash
                echo "Unknown option: ${!OPTIND}"
                show_help
                exit 1
                ;;
            *)
                remaining_args+=("${!OPTIND}")
                local OPTIND=$((OPTIND + 1))
                ;;
        esac
    done
    
    # Process remaining arguments as KEY=VALUE pairs
    for arg in "${remaining_args[@]}"; do
        if [[ "$arg" =~ ^([A-Z_]+)=(.*)$ ]]; then
            local key="${BASH_REMATCH[1]}"
            local value="${BASH_REMATCH[2]}"
            export "$key"="$value"
        fi
    done
}

