    echo "  -o <output_dir>   Specify output directory path (default: ./output)"
    echo "  -d                Dry run mode (show commands without execution)"
    echo "  -h                Show this help message"
    echo ""
    echo "Additional parameters (KEY=VALUE format):"
    echo "  DURATION=<seconds>          Set unified test duration (default: 10)"
    echo "  CPU_ENABLED=true|false      Enable/Disable CPU test (default: true)"
    echo "  CPU_MAX_PRIME=<number>      Set maximum prime number for CPU test (default: 20000)"
    echo "  MEMORY_ENABLED=true|false   Enable/Disable Memory test (default: true)"
    echo "  IO_ENABLED=true|false       Enable/Disable IO test (default: true)"
    echo "  IO_TOOL=sysbench|fio        Set IO test tool (default: sysbench)"
    echo "  NETWORK_ENABLED=true|false  Enable/Disable Network test (default: false)"
