set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# 默认参数
CONFIG_FILE=""
OUTPUT_DIR="./output"
DRY_RUN=false

# 立即 export 供库函数使用
export OUTPUT_DIR

# 解析命令行参数
parse_args() {
    local OPTIND=1
    while getopts "c:o:dh" opt; do
        case "$opt" in
            c)
                CONFIG_FILE="$OPTARG"
                ;;
            o)
                OUTPUT_DIR="$OPTARG"
                ;;
            d)
                DRY_RUN=true
                ;;
            h)
                show_help
                exit 0
                ;;
            *)
                show_help
                exit 1
                ;;
        esac
    done
    shift $((OPTIND-1))
    
    # 处理额外的参数（键值对形式）
    for arg in "$@"; do
        if [[ "$arg" =~ ^([A-Z_]+)=(.*)$ ]]; then
            local key="${BASH_REMATCH[1]}"
            local value="${BASH_REMATCH[2]}"
            # 导出为环境变量，这样可以覆盖配置文件中的值
            export "$key"="$value"
        fi
    done
}

